<?xml version="1.0" encoding="UTF-8"?>
<xsl:stylesheet version="1.0" xmlns:xsl="http://www.w3.org/1999/XSL/Transform">

  <xsl:output method="html" encoding="UTF-8" indent="yes"/>

  <xsl:template match="/">
    <html>
      <head>
        <title>Dinosaur List</title>
        <style>
          body { font-family: Arial, sans-serif; margin: 20px; }
          h1 { text-align: center; }
          table { border-collapse: collapse; width: 100%; margin-top: 20px; }
          th { background-color: #4CAF50; color: white; padding: 10px; text-align: left; }
          td { padding: 8px 10px; border: 1px solid #ddd; }
          tr:nth-child(even) { background-color: #f2f2f2; }
        </style>
      </head>
      <body>
        <h1>Dinosaur List</h1>
        <table border="1">
          <tr>
            <th>Name</th>
            <th>Period</th>
            <th>Group</th>
            <th>Range</th>
            <th>Height</th>
            <th>Length</th>
            <th>Weight</th>
          </tr>
          <xsl:for-each select="DinoList/Dinosaur">
            <tr>
              <td><xsl:value-of select="Name"/></td>
              <td>
                <xsl:choose>
                  <xsl:when test="@period"><xsl:value-of select="@period"/></xsl:when>
                  <xsl:otherwise>N/A</xsl:otherwise>
                </xsl:choose>
              </td>
              <td><xsl:value-of select="Group"/></td>
              <td>
                <xsl:for-each select="Range/Region">
                  <xsl:value-of select="."/>
                  <xsl:if test="position() != last()">, </xsl:if>
                </xsl:for-each>
              </td>
              <td>
                <xsl:choose>
                  <xsl:when test="PhysicalAttr/Height">
                    <xsl:value-of select="PhysicalAttr/Height"/>
                    <xsl:text> </xsl:text>
                    <xsl:value-of select="PhysicalAttr/Height/@unit"/>
                  </xsl:when>
                  <xsl:otherwise>N/A</xsl:otherwise>
                </xsl:choose>
              </td>
              <td>
                <xsl:choose>
                  <xsl:when test="PhysicalAttr/Length">
                    <xsl:value-of select="PhysicalAttr/Length"/>
                    <xsl:text> </xsl:text>
                    <xsl:value-of select="PhysicalAttr/Length/@unit"/>
                  </xsl:when>
                  <xsl:otherwise>N/A</xsl:otherwise>
                </xsl:choose>
              </td>
              <td>
                <xsl:choose>
                  <xsl:when test="PhysicalAttr/Weight">
                    <xsl:value-of select="PhysicalAttr/Weight"/>
                    <xsl:text> </xsl:text>
                    <xsl:value-of select="PhysicalAttr/Weight/@unit"/>
                  </xsl:when>
                  <xsl:otherwise>N/A</xsl:otherwise>
                </xsl:choose>
              </td>
            </tr>
          </xsl:for-each>
        </table>
      </body>
    </html>
  </xsl:template>

</xsl:stylesheet>